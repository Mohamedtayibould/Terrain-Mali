# ============================================
# TERRAIN MALI - Backend Environment Variables
# ============================================

# Server
PORT=5000

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:5173

# Backend URL (for Orange Money webhooks)
BACKEND_URL=http://localhost:5000

# ============================================
# SUPABASE
# ============================================
# Get these from: https://app.supabase.com > Project Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# ============================================
# ORANGE MONEY MALI (Web Payment API)
# ============================================
# Get these from: https://developer.orange.com
ORANGE_MONEY_API_URL=https://api.orange.com/orange-money-webpay/dev/v1
ORANGE_MONEY_MERCHANT_KEY=your-merchant-key
ORANGE_MONEY_API_KEY=your-api-key
ORANGE_MONEY_WEBHOOK_SECRET=your-webhook-secret
